{
    "extends": "../../tsconfig.build.json",
    "include": [
        "src"
    ],
    "compilerOptions": {
        "declarationDir": "dist",
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "types": [
            "node"
        ],
        "paths": {
            "@domain/*": [
                "./src/domain/*"
            ],
            "@value-objects/*": [
                "./src/domain/value-objects/*"
            ],
            "@application/*": [
                "./src/application/*"
            ]
        }
    }
}