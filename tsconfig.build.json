{
    "extends": "../../tsconfig.build.json",
    "include": [
        "src"
    ],
    "compilerOptions": {
        "declarationDir": "dist",
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "types": [
            "node"
        ],
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@core/*": [
                "./src/modules/core/*"
            ],
            "@user/*": [
                "./src/modules/user/*"
            ],
            "@auth/*": [
                "./src/modules/auth/*"
            ],
        }
    }
}