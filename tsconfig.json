{
  "extends": "./tsconfig.build.json",
  "compilerOptions": {
    "lib": [
      "es2023"
    ],
    "rootDir": "./src",
    "target": "es2022",
    "types": [
      "node",
      "vitest/globals",
    ],
    "experimentalDecorators": true,
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
  ]
}